#: tools/bobgui-rendernode-tool.c:35
#, c-format
#| msgid ""
#| "Usage:\n"
#| "  bobgui4-rendernode-tool [COMMAND] [OPTION…] FILE\n"
#| "\n"
#| "Perform various tasks on BOBGUI render nodes.\n"
#| "\n"
#| "Commands:\n"
#| "  benchmark    Benchmark rendering of a node\n"
#| "  compare      Compare nodes or images\n"
#| "  convert      Convert into nodes\n"
#| "  extract      Extract data urls\n"
#| "  info         Provide information about the node\n"
#| "  show         Show the node\n"
#| "  render       Take a screenshot of the node\n"
#| "\n"
msgid ""
"Usage:\n"
"  bobgui4-rendernode-tool [COMMAND] [OPTION…] FILE\n"
"\n"
"Perform various tasks on BOBGUI render nodes.\n"
"\n"
"Commands:\n"
"  benchmark    Benchmark rendering of a node\n"
"  compare      Compare nodes or images\n"
"  convert      Convert into nodes\n"
"  extract      Extract data urls\n"
"  info         Provide information about the node\n"
"  match        Match pattern in the node\n"
"  show         Show the node\n"
"  render       Take a screenshot of the node\n"
"\n"
msgstr ""
"Користування:\n"
"  bobgui4-rendernode-tool [КОМАНДА] [ПАРАМЕТР…] ФАЙЛ\n"
"\n"
"Виконати різноманітні дії з файлами .ui BobguiBuilder.\n"
"\n"
"Команди:\n"
"  benchmark    Тестувати обробку вузла\n"
"  compare      Порівняти вузли або зображення\n"
"  convert      Перетворити на вузли\n"
"  extract      Видобути адреси даних\n"
"  info         Надати дані щодо вузла\n"
"  match        Шукати за взірцем у вузлі\n\n"
"  show         Показати вузол\n"
"  render       Створити знімок вікна вузла\n"
"\n"

