<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="BobguiAspectFrame">
    <property name="child">
      <object class="BobguiLabel">
        <property name="label">start</property>
      </object>
    </property>
  <object class="GtkBox">
    <child>
      <object class="GtkLabel"/>
      <packing>
        <property name="expand">1</property>
      </packing>
    </child>
  </object>
</interface>
